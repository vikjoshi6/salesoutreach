TARGET_METRO="Mississauga, Canada"
AGENCY_NAME="Your AI Consulting Agency"
SENDER_NAME="Your Name"
REPLY_EMAIL="you@example.com"
AGENCY_PHONE=""
PHYSICAL_MAILING_ADDRESS="123 Main St, City, Province Postal Code"

# Optional future production storage. Leave blank to use local files plus Google Sheets.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Optional discovery adapter. CSV import works without this.
GOOGLE_PLACES_API_KEY=""
ENABLE_GOOGLE_PLACES_DISCOVERY=false

# Optional hosted base URL for generated mockup pages after Vercel deploy.
MOCKUP_BASE_URL="http://localhost:3000"
GOOGLE_SHEET_URL="https://docs.google.com/spreadsheets/d/10u-6zqvC4c1whfCntRQVUGZsUzXx4N12Q6yO5krISQQ/edit"

# Safe defaults for a personal Gmail launch.
DAILY_DISCOVERY_LIMIT=36
DAILY_DRAFT_LIMIT=15
DRY_RUN=true
